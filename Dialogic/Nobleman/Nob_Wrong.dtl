update Nobleman (Mad)
set {Random_Value} = range(0,2).pick_random()
label Wrong
if {Random_Value} == 0.0:
	Nobleman: I don’t know what this is, but this is not what I requested.
	leave --All-- [animation="Slide To Right" length="1.0" wait="true"]
	jump Orders/
elif {Random_Value} == 1.0:
	Nobleman: Clearly you made a mistake, as this is not what I need.
	leave --All-- [animation="Slide To Right" length="1.0" wait="true"]
	jump Orders/
else:
	jump Wrong