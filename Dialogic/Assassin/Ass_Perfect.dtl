update Assassin (Happy)
[signal arg="perfect_serve"]
label Perfect_Order
set {Random_Value} = range(0,2).pick_random()
if {Random_Value} == 0.0:
	Assassin: Excellent. Exactly what I want. Goodbye.
	leave --All-- [animation="Slide To Right" length="1.0" wait="true"]
	jump Orders/
elif {Random_Value} == 1.0:
	Assassin: Perfect. You make a fine potion. Farewell.
	leave --All-- [animation="Slide To Right" length="1.0" wait="true"]
	jump Orders/
else:
	jump Perfect_Order